#!/usr/bin/env bash

source "bashbasicsbyvk_run.sh"
source "bashbasicsbyvk_organise.sh"
source "bashbasicsbyvk_find.sh"
source "bashbasicsbyvk_settings.sh"
source "bashbasicsbyvk_transfer.sh"
source "bashbasicbyvk_shortpath.sh"
source "bashbasicsbyvk_mapper.sh"
source "bashbasicsbyvk_help.sh"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

parse_selection() {
  local input="$1"
  local max="$2"
  local -a indices=()
  IFS=',' read -ra parts <<< "$input"
  for part in "${parts[@]}"; do
    part=$(echo "$part" | xargs)
    if [[ $part =~ ^([0-9]+)-([0-9]+)$ ]]; then
      local start="${BASH_REMATCH[1]}"
      local end="${BASH_REMATCH[2]}"
      for ((i=start; i<=end && i<=max; i++)); do
        indices+=("$i")
      done
    elif [[ $part =~ ^[0-9]+$ ]]; then
      local num="$part"
      (( num >= 1 && num <= max )) && indices+=("$num")
    fi
  done
  echo "${indices[@]}"
}

select_items_common() {
  local prompt="$1"
  if [ ${#items[@]} -eq 0 ]; then
    echo "❌ No items available"
    return 1
  fi
  echo "$prompt (supports ranges: 1-10,15-20,33)"
  read -p "Item numbers: " itemlist
  local indices=($(parse_selection "$itemlist" "${#items[@]}"))
  selected_items=()
  for idx in "${indices[@]}"; do
    selected_items+=("${items[$((idx-1))]}")
  done
  if [ ${#selected_items[@]} -eq 0 ]; then
    echo "❌ No valid items selected"
    return 1
  fi
  return 0
}


select_imaginary_items_common() {
  local p="$1"
  local pfx="$2"
  echo "Select group numbers (supports ranges: 1-3,5):"
  read -p "Group numbers: " grplist
  local indices=($(parse_selection "$grplist" "${#imaginary_map[@]}"))
  if [ "${#indices[@]}" -eq 0 ]; then
    echo "❌ No valid groups selected"
    return 1
  fi
  selected_items=()
  for idx in "${indices[@]}"; do
    local ch="${imaginary_map[$((idx-1))]}"
    local ch_lower="${ch,,}"
    while IFS= read -r -d '' f; do
      local bn="${f##*/}"
      [[ "$bn" == "." || "$bn" == ".." ]] && continue
      ! $show_hidden_files && [[ "$bn" == .* ]] && continue
      local bn_lower="${bn,,}"
      [[ "$bn_lower" != "$pfx"* ]] && continue
      local next_char="${bn_lower:${#pfx}:1}"
      if [ "$ch" == "#" ]; then
        # # group: only items whose next char has no explicit group
        case "$next_char" in
          [a-zA-Z0-9]|_|.|'-'|'('|')'|'['|']'|'{'|'}'|@|'!'|'~'|'+'|'='|'^'|'&'|'%'|'$'|','|';'|"'"|' ')
            continue ;;
        esac
      else
        [[ "$next_char" != "$ch_lower" ]] && continue
      fi
      selected_items+=("$f")
    done < <(find "$p" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
  done
  local -A _seen=()
  local unique=()
  for f in "${selected_items[@]}"; do
    [ -z "${_seen[$f]+x}" ] && unique+=("$f") && _seen["$f"]=1
  done
  selected_items=("${unique[@]}")
  if [ "${#selected_items[@]}" -eq 0 ]; then
    echo "❌ No items found for selected groups"
    return 1
  fi
  return 0
}

get_abs_path() {
  local target="$1"
  if [ -d "$target" ]; then
    cd -- "$target" && pwd
  elif [ -f "$target" ]; then
    local dir=$(dirname -- "$target")
    local base=$(basename -- "$target")
    echo "$(cd -- "$dir" && pwd)/$base"
  else
    echo "Error: '$target' does not exist" >&2
    return 1
  fi
}

create_files() {
  read -p "📄 Enter filenames (separated by ,): " filelist
  IFS=',' read -ra files <<< "$filelist"
  for file in "${files[@]}"; do
    file=$(echo "$file" | xargs)
    [ -z "$file" ] && continue

    local base ext newname count target
    base="${file%.*}"
    ext="${file##*.}"
    [[ "$file" == "$ext" ]] && ext=""

    count=1
    newname="$file"
    while [ -e "$path/$newname" ]; do
      if [ -n "$ext" ]; then
        newname="${base} (${count}).${ext}"
      else
        newname="${base} (${count})"
      fi
      count=$((count+1))
    done

    touch "$path/$newname"
    echo "✅ Created file: $newname"
  done
}

create_dirs() {
  read -p "📂 Enter folder names (separated by ,): " dirlist
  IFS=',' read -ra dirs <<< "$dirlist"
  for dir in "${dirs[@]}"; do
    mkdir -p "$path/$dir"
    echo "✅ Created folder: $dir"
  done
}

delete_items() {
  local _ok=false
  if $imaginary_mode; then
    select_imaginary_items_common "$path" "$group_prefix" && _ok=true
  else
    select_items_common "DELETE" && _ok=true
  fi
  if $_ok; then
    local _has_shortcuts=false
    for _si in "${selected_items[@]}"; do
      [[ "${_si##*/}" == *.shortcut ]] && _has_shortcuts=true && break
    done
    if $_has_shortcuts; then
      echo "Note: shortcut(s) selected — only the shortcut pointer will be deleted, not the original file/folder."
    fi

    read -p "Are you really sure you want to delete the selected files? This action can't be undone. (y/n): " confirm
    if [[ $confirm != "y" && $confirm != "Y" ]]; then
      echo "🚫 Deletion cancelled"
      return
    fi
    for item in "${selected_items[@]}"; do
      rm -rf -- "$item"
    done
    echo "✅ Selected items deleted. I can feel the space 🚀"
  fi
}

fast_count() {
  local pattern="$1"
  local arr=("$pattern")
  echo "${#arr[@]}"
}

count_items_in_path() {
  local p="$1"
  local total
  if $show_hidden_files; then
    local a=("$p"/*)
    local b=("$p"/.*)
    local count_a="${#a[@]}"
    local count_b="${#b[@]}"
    [[ "${a[0]}" == "$p/*" ]] && count_a=0
    local filtered=0
    for x in "${b[@]}"; do
      local bn; bn=$(basename "$x")
      [[ "$bn" == "." || "$bn" == ".." ]] && continue
      ((filtered++))
    done
    total=$((count_a + filtered))
  else
    local a=("$p"/*)
    total="${#a[@]}"
    [[ "${a[0]}" == "$p/*" ]] && total=0
  fi
  echo "$total"
}

build_items_for_prefix() {
  build_items_with_meta "$1" "$2"
  apply_sort
}

build_all_items() {
  build_items_with_meta "$1" ""
  apply_sort
}

get_imaginary_groups() {
  local p="$1"
  local pfx="$2"
  declare -gA group_counts=()
  group_chars=()
  local chars=()
  local -A _seen_chars=()

  while IFS= read -r -d '' entry; do
    local bn="${entry##*/}"
    [[ "$bn" == "." || "$bn" == ".." ]] && continue
    if ! $show_hidden_files && [[ "$bn" == .* ]]; then
      continue
    fi
    [[ ${#bn} -le ${#pfx} ]] && continue
    local bn_lower="${bn,,}"
    [[ "$bn_lower" != "$pfx"* ]] && continue
    local next="${bn_lower:${#pfx}:1}"

    if [[ "$next" =~ ^[a-z]$ ]]; then
      local upper="${next^^}"
      group_counts["$upper"]=$(( ${group_counts["$upper"]:-0} + 1 ))
      [ -z "${_seen_chars["$upper"]+x}" ] && chars+=("$upper") && _seen_chars["$upper"]=1
    elif [[ "$next" =~ ^[0-9]$ ]]; then
      group_counts["$next"]=$(( ${group_counts["$next"]:-0} + 1 ))
      [ -z "${_seen_chars["$next"]+x}" ] && chars+=("$next") && _seen_chars["$next"]=1
    else
      case "$next" in
        _|.|'-'|'('|')'|'['|']'|'{'|'}'|@|'!'|'~'|'+'|'='|'^'|'&'|'%'|'$'|','|';'|"'"|' ')
          group_counts["$next"]=$(( ${group_counts["$next"]:-0} + 1 ))
          [ -z "${_seen_chars["$next"]+x}" ] && chars+=("$next") && _seen_chars["$next"]=1
          ;;
        *)
          group_counts["#"]=$(( ${group_counts["#"]:-0} + 1 ))
          [ -z "${_seen_chars["#"]+x}" ] && chars+=("#") && _seen_chars["#"]=1
          ;;
      esac
    fi
  done < <(find "$p" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)

  group_chars=("${chars[@]}")
}

display_imaginary_groups() {
  local p="$1"
  local pfx="$2"
  local total="$3"
  echo "📂 Too many items ($total). Imaginary groups by next character:"
  get_imaginary_groups "$p" "$pfx"

  # Sort: special chars → digits → letters → #
  local specials=()
  local digits=()
  local letters=()
  local fallback=()

  for ch in "${group_chars[@]}"; do
    if [[ "$ch" =~ ^[A-Z]$ ]]; then
      letters+=("$ch")
    elif [[ "$ch" =~ ^[0-9]$ ]]; then
      digits+=("$ch")
    elif [[ "$ch" == "#" ]]; then
      fallback+=("$ch")
    else
      specials+=("$ch")
    fi
  done

  IFS=$'\n' sorted_specials=($(printf '%s\n' "${specials[@]}" | sort))
  IFS=$'\n' sorted_digits=($(printf '%s\n' "${digits[@]}" | sort))
  IFS=$'\n' sorted_letters=($(printf '%s\n' "${letters[@]}" | sort))
  unset IFS

  local sorted=("${sorted_specials[@]}" "${sorted_digits[@]}" "${sorted_letters[@]}" "${fallback[@]}")

  imaginary_map=()
  local idx=1
  for ch in "${sorted[@]}"; do
    local cnt="${group_counts[$ch]}"
    printf " %2d) 📁 %s (%d items)\n" "$idx" "$ch" "$cnt"
    imaginary_map+=("$ch")
    idx=$((idx+1))
  done
}

handle_force_show() {
  if $force_show; then
    force_show=false
    echo "🔓 Force show disabled"
  else
    force_show=true
    echo "🔓 Force show enabled — displaying all items"
  fi
}

handle_create() {
  echo "Create:"
  echo "1) New folders"
  echo "2) New files"
  read -p "Choice: " cr
  [[ "$cr" == "1" ]] && create_dirs
  [[ "$cr" == "2" ]] && create_files
}

handle_rename() {
  if [ ${#items[@]} -eq 0 ]; then
    echo "❌ No items to rename"
    return
  fi
  select_items_common "RENAME"
  [ $? -ne 0 ] && return

  for item in "${selected_items[@]}"; do
    local bn="${item##*/}"

    if [[ "$bn" == *.shortcut ]]; then
      local cur_name
      cur_name=$(_shortcut_read_field "$item" "SHORTCUT_NAME")
      [ -z "$cur_name" ] && cur_name="${bn%.shortcut}"
      local sc_type_r
      sc_type_r=$(_shortcut_read_field "$item" "SHORTCUT_TYPE")
      [ "$sc_type_r" == "dir" ] && echo "🔑  Shortcut (dir): $cur_name" || echo "🗝️  Shortcut (file): $cur_name"
      echo "Renaming a shortcut only changes the shortcut's name — the original is untouched."
      read -p "New display name (blank = cancel): " new_name
      [ -z "$new_name" ] && echo "🚫 Skipped" && continue

      local tmp_file
      tmp_file=$(mktemp)
      sed "s|^SHORTCUT_NAME=.*|SHORTCUT_NAME=${new_name}|" "$item" > "$tmp_file" && mv "$tmp_file" "$item"

      local new_sc_path
      new_sc_path="$(dirname "$item")/${new_name}.shortcut"
      local count=1
      while [ -e "$new_sc_path" ] && [ "$new_sc_path" != "$item" ]; do
        new_sc_path="$(dirname "$item")/${new_name}${count}.shortcut"
        count=$((count+1))
      done
      if [ "$new_sc_path" != "$item" ]; then
        mv -- "$item" "$new_sc_path"
      fi
      echo "✅ Shortcut renamed: $cur_name → $new_name"
      continue
    fi

    echo "Current name: $bn"
    read -p "New name (blank = cancel): " new_name
    [ -z "$new_name" ] && echo "🚫 Skipped" && continue
    local new_path
    new_path="$(dirname "$item")/$new_name"
    if [ -e "$new_path" ]; then
      echo "⚠️  '$new_name' already exists — skipped"
      continue
    fi
    mv -- "$item" "$new_path"
    echo "✅ Renamed: $bn → $new_name"
  done
}

infinity_stones_menu() {
  echo
  echo "💎 Infinity Stones"
  echo "1) Extract Tables and Links from Web"
  echo "2) Generate SQL"
  echo "3) JavaScript Audit"
  echo "4) Git Push"
  echo "0) Back"
  read -p "Choice: " is_choice
  case "$is_choice" in
    1) python "$SCRIPT_DIR/_3bvk_xtract_core" "$path";;
    2) python "$SCRIPT_DIR/_3bvk_gen_sql_core" "$path";;
    3) python "$SCRIPT_DIR/_3bvk_js_audit_core" "$path" ;;
    4) bash "$SCRIPT_DIR/_3bvk_gitpush_core" "$path";;
    0|"") return ;;
    *) echo "⚠️  Invalid choice" ;;
  esac
}

handle_selection() {
  local choice="$1"
  if $imaginary_mode; then
    local matched=false
    local ch=""

    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#imaginary_map[@]}" ]; then
      ch="${imaginary_map[$((choice-1))]}"
      matched=true
    elif [[ ${#choice} -eq 1 ]]; then
      local uc="${choice^^}"
      for gc in "${imaginary_map[@]}"; do
        if [[ "$gc" == "$uc" ]] || [[ "$gc" == "$choice" ]]; then
          ch="$gc"
          matched=true
          break
        fi
      done
    fi

    if $matched; then
      if [ "$ch" == "#" ]; then
        # True fallback group — collect and display directly, don't append to prefix
        imaginary_mode=false
        items=()
        while IFS= read -r -d '' _f; do
          _bn="${_f##*/}"
          [[ "$_bn" == "." || "$_bn" == ".." ]] && continue
          ! $show_hidden_files && [[ "$_bn" == .* ]] && continue
          local _bn_lower="${_bn,,}"
          [ -n "$group_prefix" ] && [[ "$_bn_lower" != "$group_prefix"* ]] && continue
          local _next="${_bn_lower:${#group_prefix}:1}"
          # only include items whose next char has no explicit group
          case "$_next" in
            [a-zA-Z0-9]|_|.|'-'|'('|')'|'['|']'|'{'|'}'|@|'!'|'~'|'+'|'='|'^'|'&'|'%'|'$'|','|';'|"'"|' ')
              continue ;;
          esac
          items+=("$_f")
        done < <(find "$path" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
        _collect_metadata
        apply_sort
      elif [[ "$ch" =~ ^[A-Z]$ ]]; then
        group_prefix="${group_prefix}${ch,,}"
        force_show=false
      else
        # digit or special char — append literally
        group_prefix="${group_prefix}${ch}"
        force_show=false
      fi
    else
      echo "⚠️  Invalid selection"
    fi
  else
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#items[@]}" ]; then
      selected="${items[$((choice-1))]}"
      local bn="${selected##*/}"

      if [[ "$bn" == *.shortcut ]]; then
        local sc_target sc_type
        sc_target=$(_shortcut_resolve "$selected")
        if [ $? -ne 0 ]; then
          echo "💡 The shortcut file is still present — you can delete or rename it."
          return
        fi
        sc_type=$(_shortcut_read_field "$selected" "SHORTCUT_TYPE")

        if [ "$sc_type" == "dir" ] || [ -d "$sc_target" ]; then
          path="$sc_target"
          group_prefix=""
          force_show=false
        else
          handle_file "$sc_target"
        fi
        return
      fi

      if [ -d "$selected" ]; then
        path="$selected"
        group_prefix=""
        force_show=false
      elif [ -f "$selected" ]; then
        handle_file "$selected"
      fi
    else
      echo "⚠️  Invalid selection"
    fi
  fi
}


_orig_stty=$(stty -g 2>/dev/null)
trap 'stty "$_orig_stty" 2>/dev/null' EXIT

_menu_header() {
  echo
  echo "📂 Location: $path${group_prefix:+ [filter: ${group_prefix^^}*]}"
}

_menu_body_flat() {
  if $_has_group_view; then
    _gv_chain="${group_view_levels[*]}"
    echo "🗂️  Group view: ${_gv_chain// / → }  (change in Settings → 9)"
  fi
  display_items
}

_menu_footer_lines() {
  echo
  echo "u) Up   cd) Change directory   t) Transfer"
  echo "d) Delete   c) Create   f) Find    r) Rename"
  echo "q/h) Quit/Home   s) Settings   x) Organise"
  echo "-h) Help   -u) Upgrade"
  echo "up-1,3 / ups-1,3) Upload to cloud (multi-file/folder vs single merged file)   do-) Import a pasted link"
  [ -n "$group_prefix" ] && echo "back) Remove last prefix char (current: ${group_prefix^^}*)"
  if [ "$total" -gt "${index_mode_threshold:-200}" ] && ! $force_show && [ "${#group_view_levels[@]}" -gt 0 ]; then
    echo "Group view is set but above threshold → press forceshow to enable grouped display"
  fi
}

# Number of lines printed AFTER the item list but before the "Select:"
# line, so we can compute exactly how far to move the cursor to reach
# a given item's row. Computed by actually running _menu_footer_lines
# rather than a hardcoded number, so it can never drift out of sync
# when the footer text changes.
_footer_line_count() {
  _menu_footer_lines | wc -l | tr -d ' '
}

# Un-highlights the old row and highlights the new row in place, without
# touching or reprinting anything else on screen. Only valid for the
# flat (non-grouped) item list, where each item occupies exactly one
# line — grouped view falls back to a full redraw since group headers
# make row positions harder to predict.
_redraw_highlight_inplace() {
  local old_idx="$1" new_idx="$2"
  local n_items=${#items[@]}
  local footer; footer=$(_footer_line_count)

  tput sc 2>/dev/null

  if [ "$old_idx" -ge 1 ] && [ "$old_idx" -le "$n_items" ]; then
    local dist=$(( footer + (n_items - old_idx + 1) ))
    printf '\033[%dA\r\033[K' "$dist"
    printf '%s' "$(_item_line_text "$old_idx")"
    tput rc 2>/dev/null
  fi

  if [ "$new_idx" -ge 1 ] && [ "$new_idx" -le "$n_items" ]; then
    local dist=$(( footer + (n_items - new_idx + 1) ))
    printf '\033[%dA\r\033[K' "$dist"
    printf '%s' "$(_highlight "$(_item_line_text "$new_idx")")"
    tput rc 2>/dev/null
  fi
}

_redraw_menu() {
  _menu_header
  _menu_body_flat
  _menu_footer_lines
}

# Redraws just the "Select: " input line in place (no full-screen clear),
# leaving the terminal cursor at the correct character position.
_print_input_line() {
  printf '\r\033[K'
  printf "Select: %s" "$_buf"
  local back=$(( ${#_buf} - _pos ))
  [ "$back" -gt 0 ] && printf '\033[%dD' "$back"
}

# If what's been typed so far is a plain number, move the highlighted
# item to match it live (so typing "2" highlights item 2 immediately,
# before Enter is even pressed).
_sync_highlight_from_buf() {
  $_can_nav || return
  [[ "$_buf" =~ ^[0-9]+$ ]] || return
  local n=$((10#$_buf))
  (( n < 1 )) && n=1
  (( n > ${#items[@]} )) && n=${#items[@]}
  if [ "$n" -ne "${_hl_index:-0}" ]; then
    local old="$_hl_index"
    _hl_index=$n
    if $_can_inplace; then
      _redraw_highlight_inplace "$old" "$_hl_index"
      _print_input_line
    else
      clear
      _redraw_menu
      _print_input_line
    fi
  fi
}

# Reads the "Select:" input.
#  - Up/Down move the highlighted item; the number is written into the
#    input line too, so pressing Down after typing "2" continues to "3".
#  - Left/Right move the text cursor within what you've typed, like a
#    normal text field, so you can edit in the middle of a number.
#  - Enter with nothing typed submits the currently highlighted item.
_read_choice() {
  choice=""
  _can_nav=false
  if ! $imaginary_mode && [ ${#items[@]} -gt 0 ]; then
    _can_nav=true
    [ "$_hl_index" -gt "${#items[@]}" ] && _hl_index="${#items[@]}"
  else
    _hl_index=0
  fi
  _can_inplace=false
  $_can_nav && ! $_has_group_view && _can_inplace=true

  stty -icanon -echo min 1 time 0 2>/dev/null

  _buf=""
  _pos=0
  local key seq
  _print_input_line

  while true; do
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn2 -t 0.05 seq
      case "$seq" in
        '[A')  # Up
          if $_can_nav; then
            local old="$_hl_index"
            if [ "$_hl_index" -lt 1 ]; then
              _hl_index="${#items[@]}"
            else
              _hl_index=$(( _hl_index - 1 ))
              [ "$_hl_index" -lt 1 ] && _hl_index="${#items[@]}"
            fi
            _buf="$_hl_index"; _pos=${#_buf}
            if $_can_inplace; then
              _redraw_highlight_inplace "$old" "$_hl_index"
              _print_input_line
            else
              clear; _redraw_menu; _print_input_line
            fi
          fi
          ;;
        '[B')  # Down
          if $_can_nav; then
            local old="$_hl_index"
            if [ "$_hl_index" -lt 1 ]; then
              _hl_index=1
            else
              _hl_index=$(( _hl_index + 1 ))
              [ "$_hl_index" -gt "${#items[@]}" ] && _hl_index=1
            fi
            _buf="$_hl_index"; _pos=${#_buf}
            if $_can_inplace; then
              _redraw_highlight_inplace "$old" "$_hl_index"
              _print_input_line
            else
              clear; _redraw_menu; _print_input_line
            fi
          fi
          ;;
        '[C')  # Right — move cursor within typed text
          if [ "$_pos" -lt "${#_buf}" ]; then
            _pos=$(( _pos + 1 ))
            printf '\033[1C'
          fi
          ;;
        '[D')  # Left — move cursor within typed text
          if [ "$_pos" -gt 0 ]; then
            _pos=$(( _pos - 1 ))
            printf '\033[1D'
          fi
          ;;
        *) : ;;  # unrecognized escape sequence, swallow it
      esac
      continue
    fi

    case "$key" in
      "")  # Enter
        break
        ;;
      $'\x7f'|$'\x08')  # backspace — deletes char before cursor
        if [ "$_pos" -gt 0 ]; then
          _buf="${_buf:0:_pos-1}${_buf:_pos}"
          _pos=$(( _pos - 1 ))
          _print_input_line
          _sync_highlight_from_buf
        fi
        ;;
      *)  # insert typed char at cursor position
        _buf="${_buf:0:_pos}${key}${_buf:_pos}"
        _pos=$(( _pos + 1 ))
        _print_input_line
        _sync_highlight_from_buf
        ;;
    esac
  done

  stty "$_orig_stty" 2>/dev/null
  echo

  if [ -n "$_buf" ]; then
    choice="$_buf"
  elif $_can_nav && [ "$_hl_index" -ge 1 ]; then
    choice="$_hl_index"
  fi
}

path=$(pwd)
selected_items=()
group_prefix=""
force_show=false
_has_group_view=false
_gv_chain=""
declare -a imaginary_map=()
declare -a group_chars=()
declare -A group_counts=()
nav_result_path=""
nav_selected_items=()
gcloud_nav_result_path=""
gcloud_nav_selected_items=()

if [ $# -eq 1 ]; then
  target="$1"
  if [ -d "$target" ]; then
    path=$(get_abs_path "$target")
  elif [ -f "$target" ]; then
    selected=$(get_abs_path "$target")
    handle_file "$selected"
    exit $?
  else
    echo "❌ Error: '$target' not found" >&2
    exit 1
  fi
fi

shopt -s nullglob
while true; do
  _menu_header

  total=$(count_items_in_path "$path")

  imaginary_mode=false
  items=()
  _hl_index=0

  _has_group_view=false
  [ "${#group_view_levels[@]}" -gt 0 ] && _has_group_view=true

  if [ "$total" -gt "${index_mode_threshold:-200}" ] && ! $force_show; then
    imaginary_mode=true
    if [ -n "$group_prefix" ]; then
      local_arr=()
      while IFS= read -r -d '' _f; do
        _bn="${_f##*/}"
        [[ "$_bn" == "." || "$_bn" == ".." ]] && continue
        ! $show_hidden_files && [[ "$_bn" == .* ]] && continue
        [[ "${_bn,,}" != "$group_prefix"* ]] && continue
        local_arr+=("$_f")
      done < <(find "$path" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
      pfx_count="${#local_arr[@]}"
      if [ "$pfx_count" -le "${index_mode_threshold:-200}" ]; then
        imaginary_mode=false
        items=("${local_arr[@]}")
        _collect_metadata
        apply_sort
      else
        display_imaginary_groups "$path" "$group_prefix" "$pfx_count"
      fi
    else
      display_imaginary_groups "$path" "" "$total"
    fi
  elif [ "$total" -gt "${index_mode_threshold:-200}" ] && $force_show; then
    imaginary_mode=false
    if [ -n "$group_prefix" ]; then
      build_items_with_meta "$path" "$group_prefix"
    else
      build_items_with_meta "$path" ""
    fi
    apply_sort
  fi

  if ! $imaginary_mode; then
    if [ ${#items[@]} -eq 0 ] && [ -n "$group_prefix" ]; then
      build_items_with_meta "$path" "$group_prefix"
      apply_sort
    elif [ ${#items[@]} -eq 0 ]; then
      build_items_with_meta "$path" ""
      apply_sort
    fi

    _menu_body_flat
  fi

  _menu_footer_lines

  _read_choice

  case "$choice" in
    q|Q)                   exit 0 ;;
    -h|-H)                 open_help ;;
    u|U)                   if [ "$path" != "/" ]; then path=$(dirname "$path"); group_prefix=""; force_show=false; fi ;;
    back)                  if [ -n "$group_prefix" ]; then group_prefix="${group_prefix%?}"; force_show=false; fi ;;
    forceshow)             handle_force_show ;;
    c|C)                   handle_create ;;
    t|T)                   transfer_menu ;;
    d|D)                   delete_items ;;
    f|F)                   find_menu ;;
    x|X)                   organise_menu ;;
    s|S)                   settings_menu ;;
    r|R)                   handle_rename ;;
    cd|CD|cD|Cd)           cd "$path" && exec "$SHELL" ;;
    m|M)                   map_directory ;;
    kl|KL|Kl|kL)           kill -9 -1 ;;
    i|I)                   infinity_stones_menu ;;
    -u|-U)                 bash _3bvk_upgrade_core ;;
    d-)                    handle_shortpath_dispatch ;;
    v-)                    handle_shortpath_view ;;
    c-*|m-*|s-*)           handle_shortpath_stage "$choice" ;;
    do-)                   handle_do_import ;;
    ups-*)                 handle_ups_upload "$choice" ;;
    up-*)                  handle_up_upload "$choice" ;;
    *)                     handle_selection "$choice" ;;
  esac

done
