#!/usr/bin/env bash

if [ -z "$1" ]; then
  echo "Usage: copy <filename>"
  exit 1
fi

if [ ! -f "$1" ]; then
  echo "Error: File '$1' not found."
  exit 1
fi

# Determine copy method
if [ -n "$DEVSHELL_PROJECT_ID" ]; then
    METHOD="OSC 52 (Cloud Shell)"
    COPY_CMD="osc52"
elif command -v pbcopy &> /dev/null; then
    METHOD="pbcopy (macOS)"
    COPY_CMD="pbcopy"
elif command -v xclip &> /dev/null; then
    METHOD="xclip (Linux/X11)"
    COPY_CMD="xclip -selection clipboard"
elif command -v xsel &> /dev/null; then
    METHOD="xsel (Linux/X11)"
    COPY_CMD="xsel --clipboard --input"
elif command -v wl-copy &> /dev/null; then
    METHOD="wl-copy (Wayland)"
    COPY_CMD="wl-copy"
elif command -v termux-clipboard-set &> /dev/null; then
    METHOD="termux-api (Android)"
    COPY_CMD="termux-clipboard-set"
elif command -v clip.exe &> /dev/null; then
    METHOD="clip.exe (WSL/Windows)"
    COPY_CMD="clip.exe"
else
    METHOD="OSC 52 (Generic Headless)"
    COPY_CMD="osc52"
fi

# OSC52 with EAGAIN handling
if [ "$COPY_CMD" == "osc52" ]; then
    FILE_SIZE=$(wc -c < "$1")
    
    # Max ~700 bytes to stay under 1024 byte write limit after base64 encoding
    # (base64 adds ~33% overhead: 700 * 1.33 = 931, plus 8 bytes OSC overhead = 939 < 1024)
    SAFE_LIMIT=700
    
    if [ "$FILE_SIZE" -gt "$SAFE_LIMIT" ] && command -v python3 &> /dev/null; then
        # Use Python to handle EAGAIN retries properly
        python3 << 'EOF' - "$1"
import sys
import os
import errno
import base64

filename = sys.argv[1]
try:
    with open(filename, 'rb') as f:
        data = f.read(74994)  # Read up to protocol max, but we'll hit safe limits first
    
    # Encode to base64
    payload = base64.b64encode(data).decode('ascii')
    
    # Build OSC52 sequence
    osc = f"\033]52;c;{payload}\a"
    if os.environ.get('TMUX') or os.environ.get('TERM', '').startswith('screen'):
        osc = f"\033Ptmux;\033{osc}\033\\"
    
    # Write to stdout with EAGAIN handling
    buf = osc.encode('latin-1')
    fd = sys.stdout.fileno()
    
    while buf:
        try:
            n = os.write(fd, buf)
            buf = buf[n:]
        except OSError as e:
            if e.errno == errno.EAGAIN:
                import select
                select.select([], [fd], [])  # Wait until writable
                continue
            raise
    
    sys.stderr.write(f"✅ Success: Contents of '{filename}' sent via OSC 52 (Python handler, {len(data)} bytes).\n")
    if len(data) == 74994:
        sys.stderr.write("   (Note: File truncated to 74KB due to protocol limits)\n")
except Exception as e:
    sys.stderr.write(f"❌ Error: {e}\n")
    sys.exit(1)
EOF
    else
        # Fallback to pure bash for small files only
        PAYLOAD=$(head -c "$SAFE_LIMIT" "$1" | base64 | tr -d '\n\r')
        
        if [ "$FILE_SIZE" -gt "$SAFE_LIMIT" ]; then
            echo "⚠️  Warning: File is ${FILE_SIZE} bytes (limit ${SAFE_LIMIT}). Truncating to prevent clipboard corruption..." >&2
            echo "   (Install python3 to handle larger files)" >&2
        fi
        
        if [ -n "$TMUX" ] || [[ "$TERM" == screen* ]]; then
            printf "\033Ptmux;\033\033]52;c;%s\a\033\\" "$PAYLOAD"
        else
            printf "\033]52;c;%s\a" "$PAYLOAD"
        fi
        echo "✅ Success: Contents of '$1' sent via $METHOD (limited to ${SAFE_LIMIT} bytes)."
    fi
else
    cat "$1" | $COPY_CMD
    echo "✅ Success: Contents of '$1' copied via $METHOD."
fi
