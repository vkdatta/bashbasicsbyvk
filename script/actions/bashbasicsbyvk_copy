#!/usr/bin/env bash

# --- CONFIGURATION ---
WORKER_URL="https://copy.bashbasics.workers.dev"

if [ -z "$1" ]; then
  echo "Usage: copy <filename>"
  exit 1
fi

if [ ! -f "$1" ]; then
  echo "Error: File '$1' not found."
  exit 1
fi

FILE="$1"

# --- DETECT BEST LOCAL METHOD ---
if command -v pbcopy &> /dev/null; then
    COPY_CMD="pbcopy"
elif command -v xclip &> /dev/null; then
    COPY_CMD="xclip -selection clipboard"
elif command -v wl-copy &> /dev/null; then
    COPY_CMD="wl-copy"
elif command -v clip.exe &> /dev/null; then
    COPY_CMD="clip.exe"
elif command -v termux-clipboard-set &> /dev/null; then
    COPY_CMD="termux-clipboard-set"
else
    # No local clipboard found, switching to Worker Bridge
    COPY_CMD="worker-bridge"
fi

# --- EXECUTION ---
if [ "$COPY_CMD" == "worker-bridge" ]; then
    ID=$(openssl rand -hex 3)
    echo "Headless environment detected. Pushing to Cloud Bridge..."
    
    # Upload to Worker
    RESPONSE=$(curl -s --fail -w "\n%{http_code}" \
        -H "Expect:" \
        -X PUT --data-binary "@$FILE" \
        "$WORKER_URL/$ID")

    EXIT_CODE=$?
    HTTP_STATUS=$(echo "$RESPONSE" | tail -n 1)
    FINAL_URL=$(echo "$RESPONSE" | head -n 1)

    if [ $EXIT_CODE -eq 0 ] && [ "$HTTP_STATUS" == "201" ]; then
        # Copy the LINK itself to clipboard via OSC 52 (Safe for small strings)
        if [[ "$TERM" == "screen"* ]] || [[ "$TERM" == "tmux"* ]]; then
            printf "\033Ptmux;\033\033]52;c;$(printf "$FINAL_URL" | base64 | tr -d '\n')\a\033\\"
        else
            printf "\033]52;c;$(printf "$FINAL_URL" | base64 | tr -d '\n')\a"
        fi

        clear
        echo -e "✅ Success: Link copied to clipboard via OSC 52."
        echo -e "-------------------------------------------"
        echo -e "Link: \e[4;34m$FINAL_URL\e[0m"
        echo -e "-------------------------------------------"
        echo "Paste (Ctrl+V) in Chrome to sync the full file."

        # Attempt to auto-open if the terminal supports it
        ( (open "$FINAL_URL" || xdg-open "$FINAL_URL" || termux-open-url "$FINAL_URL") &> /dev/null ) &
    else
        echo "❌ Error: Cloud push failed (HTTP $HTTP_STATUS)."
        exit 1
    fi
else
    # Local Copy
    cat "$FILE" | $COPY_CMD
    echo "✅ Success: Contents of '$FILE' copied via $COPY_CMD."
fi
