#!/usr/bin/env bash
set -uo pipefail

PKG_URL="git+https://github.com/vkdatta/bashbasicsbyvk.git"
CLI_ENTRY_POINT="bashbasicsbyvk_copy"   # adjust to your actual entry point name

PY_BIN=""
PIP_BIN=""

detect_python_pip() {
    if command -v python3 >/dev/null 2>&1; then PY_BIN="python3";
    elif command -v python >/dev/null 2>&1; then PY_BIN="python";
    else echo "❌ No python3/python found on PATH."; exit 1; fi

    if command -v pip >/dev/null 2>&1; then PIP_BIN="pip";
    elif command -v pip3 >/dev/null 2>&1; then PIP_BIN="pip3";
    else echo "❌ No pip/pip3 found on PATH."; exit 1; fi
}

get_break_flag() {
    local pyver ext_managed
    pyver=$("$PY_BIN" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
    ext_managed="/usr/lib/python${pyver}/EXTERNALLY-MANAGED"
    [ -f "$ext_managed" ] && echo "--break-system-packages" || echo ""
}

check_home_writable() {
    [ -w "$HOME" ] || { echo "❌ \$HOME ($HOME) is not writable — cannot install."; exit 1; }
}

run_install() {
    local break_flag; break_flag=$(get_break_flag)
    echo "Installing to user site-packages: $HOME/.local"
    "$PIP_BIN" install --user -vvv --progress-bar on --upgrade --force-reinstall "$PKG_URL" $break_flag
}

verify_on_path() {
    if command -v "$CLI_ENTRY_POINT" >/dev/null 2>&1; then
        echo "✅ '$CLI_ENTRY_POINT' is installed and reachable on PATH."
    else
        echo "⚠️  Installed, but '$CLI_ENTRY_POINT' isn't on PATH."
        echo "    Add this to your shell profile (~/.bashrc, ~/.zshrc, etc.):"
        echo '    export PATH="$HOME/.local/bin:$PATH"'
    fi
}

main() {
    detect_python_pip
    check_home_writable
    run_install
    verify_on_path
}

main