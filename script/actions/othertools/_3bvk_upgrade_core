#!/usr/bin/env bash

PYTHON_VERSION=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
EXT_MANAGED_FILE="/usr/lib/python${PYTHON_VERSION}/EXTERNALLY-MANAGED"

BREAK_FLAG=""
if [ -f "$EXT_MANAGED_FILE" ]; then
    BREAK_FLAG="--break-system-packages"
fi

PKG_URL="git+https://github.com/vkdatta/bashbasicsbyvk.git"

is_headless() {
    if [ -n "$DISPLAY" ] || [ -n "$WAYLAND_DISPLAY" ]; then
        return 1
    fi
    if [[ "$OSTYPE" == "darwin"* ]]; then
        return 1
    fi
    return 0
}

if is_headless; then
    echo "Headless environment detected (VM/CloudShell/CI) — using sudo + --break-system-packages"
    sudo pip install -vvv --progress-bar on --upgrade --force-reinstall \
        "$PKG_URL" $BREAK_FLAG
else
    echo "Non-headless environment detected — installing without sudo"
    pip install -vvv --progress-bar on --upgrade --force-reinstall \
        "$PKG_URL"
fi