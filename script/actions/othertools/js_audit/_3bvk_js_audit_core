    ROOT,
    collect_files, rel,
    JSFileInfo, HTMLFileInfo,
    _fill, _font, _align, _border_thin, _status_style,
    _dedup, _recompute_1e_merge_metadata,
)
from 3bvk_js_audit_1a import audit_1a_import_top
from 3bvk_js_audit_1b import audit_1b_export_match
from 3bvk_js_audit_1c import audit_1c_html_events
