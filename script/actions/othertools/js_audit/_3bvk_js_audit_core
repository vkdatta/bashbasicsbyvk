from openpyxl.utils import get_column_letter
from 3bvk_js_audit_constants import (
    CLR_HEADER_BG, CLR_HEADER_FG, CLR_TITLE_BG, CLR_TITLE_FG,
    CLR_OK_BG, CLR_OK_FG, CLR_ERROR_BG, CLR_ERROR_FG,
    CLR_INFO_BG, CLR_INFO_FG, CLR_DEAD_BG, CLR_DEAD_FG,
    CLR_ANN_BG, CLR_ANN_FG, CLR_1E_MERGE_BG, CLR_1E_MERGE_FG,
    CLR_ROW_ODD, CLR_ROW_EVEN,
    FONT_NAME,
